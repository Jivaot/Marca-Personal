---
import { projects } from "../data/portfolio.js";
---

<section id="proyectos" class="projects-section">
  <div class="projects-heading">
    <div>
      <p class="section-kicker">02 · Sistemas inteligentes</p>

      <h2>
        Proyectos que convierten datos en sistemas reales.
      </h2>
    </div>

    <p>
      Cada proyecto representa una forma distinta de construir inteligencia:
      buscar, detectar, gestionar, aprender, evolucionar y optimizar.
    </p>
  </div>

  <div class="projects-grid">
    {projects.map((project) => (
      <article class="project-card">
        <div class="project-number" aria-hidden="true">
          {project.number}
        </div>

        <div class="project-main">
          <p class="project-subtitle">
            {project.subtitle}
          </p>

          <h3>
            {project.title}
          </h3>

          <p>
            {project.description}
          </p>
        </div>

        <div class="project-role">
          <span>Mi rol</span>
          <strong>{project.role}</strong>
        </div>

        <div class="project-tags" aria-label={`Tecnologías y áreas de ${project.title}`}>
          {project.tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>